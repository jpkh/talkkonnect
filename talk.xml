      <serverandport>10.10.32.5:64738</serverandport>

      <!-- =====================================================================
           Hypcom Intercom System — Mumble Server Layout (10.10.33.5:64738)

           Patient / EPAT users (each in their own channel, never move):
             Ch: Pat1..Pat12   ->  User: Pat1..Pat12
             Ch: PatPL1        ->  User: PatPL1
             Ch: PatPL2        ->  User: PatPL2
             Ch: PatPL3        ->  User: PatPL3
             EPAT units share this same config; only username/channel differ.

           MIC units (each in their own channel, never move):
             Ch: SL   ->  User: SL-MIC
             Ch: PL   ->  User: PL-MIC
             Ch: TC   ->  Users: TC1-MIC, TC2-MIC

           Operator & Staff:
             Ch: Staff  ->  Users: Oper, Staff1..Staff6

           Audio broadcast (entertainment, one-way RX only):
             Ch: Audio  ->  User: Audio-bcast (continuously streams music)
             PAT/EPAT subscribe as channel listeners via listeningstart/listeningstop.
             No user ever transmits into the Audio channel.

           PAT/EPAT voice target (TX whisper) policy:
             VT=1  ->  Oper  (set once when unit comes online; never changed)
             TX gated by starttransmitting / stoptransmitting commands from VGM.
           ===================================================================== -->

      <username>P12</username>
      <password></password>
      <insecure>true</insecure>
      <register>false</register>
      <certificate></certificate>
      <channel>Pat12</channel>
      <ident>Pat12</ident>

      <!-- PAT audio-listen sources (RX-only additional channels).
           Keep only channels that PAT is allowed to monitor. -->
      <listentochannels>
